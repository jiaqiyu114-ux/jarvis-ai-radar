# J.A.R.V.I.S. Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

# Supabase — required for real data; app works with mock data if these are empty
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: protect POST /api/fetch/rss in production.
# If set, every POST request must include header:  x-jarvis-secret: <value>
# Leave empty during local development for convenience.
JARVIS_FETCH_SECRET=
