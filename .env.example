# J.A.R.V.I.S. Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

# ── Supabase (required for database mode) ────────────────────────────────────
# App works with mock data if these are empty — no crash.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase service role (optional, recommended for production) ───────────────
# Bypasses Row Level Security — required when RLS policies are enabled.
# If not set, NEXT_PUBLIC_SUPABASE_ANON_KEY is used for server-side writes.
# MVP note: no RLS is currently configured, so anon key is sufficient.
# NEVER expose this key to the browser — server/API routes only.
SUPABASE_SERVICE_ROLE_KEY=

# ── RSS fetch protection (optional) ───────────────────────────────────────────
# If set, POST /api/fetch/rss requires header: x-jarvis-secret: <value>
# Leave empty during local development.
JARVIS_FETCH_SECRET=
